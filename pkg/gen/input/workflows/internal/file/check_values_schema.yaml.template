name: 'Values and schema'

on:
  pull_request:
    branches:
      - master
      - main
    paths:
      - 'helm/**/values.yaml'         # default helm chart values
      - 'helm/**/values.schema.json'  # schema
      - 'helm/**/ci/ci-values.yaml'   # overrides for CI (can contain required entries)

