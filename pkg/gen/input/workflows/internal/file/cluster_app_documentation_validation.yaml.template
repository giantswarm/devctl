{{{{ .Header }}}}

name: Documentation validation

on:
  pull_request:
    branches:
      - master
      - main
    paths:
      - 'helm/**/values.yaml'
      - 'helm/**/values.schema.json'
      - '**/*.md'

  push: {}

permissions: {}

jobs:
  validate:
    uses: giantswarm/github-workflows/.github/workflows/documentation-validation.yaml@d99b0e49654737f20447beccd25e3dfd111dec69 # main
    permissions:
      contents: read
