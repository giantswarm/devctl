{{{{ .Header }}}}
name: Release Please

on:
  push:
    branches:
      - main
      - master

permissions: {}

jobs:
  release_please:
    uses: giantswarm/github-workflows/.github/workflows/release.yaml@main
    permissions:
      contents: write
      pull-requests: write
    secrets:
      RELEASE_PLEASE_APP_ID: ${{ secrets.RELEASE_PLEASE_APP_ID }}
      RELEASE_PLEASE_PRIVATE_KEY: ${{ secrets.RELEASE_PLEASE_PRIVATE_KEY }}
